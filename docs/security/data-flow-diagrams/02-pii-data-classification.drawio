<mxGraphModel adaptiveColors="auto" dx="900" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1230" pageHeight="600" math="0" shadow="0">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <mxCell id="title" value="Personal Data (PII) — What Jetstream Stores and How It Is Protected" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0b1b3a;fontColor=#ffffff;fontStyle=1;fontSize=16;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1150" height="40" as="geometry"/></mxCell>

    <mxCell id="banner" value="Baseline for everything below: the entire production database is encrypted at rest.&#10;The colors indicate the ADDITIONAL, application-level protection applied on top of encryption at rest." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f4ea;strokeColor=#137333;fontColor=#062916;fontStyle=1;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="70" width="1150" height="46" as="geometry"/></mxCell>

    <mxCell id="containerA" value="Personal data Jetstream stores about its USERS — PostgreSQL (encrypted at rest)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#9aa0a6;fontColor=#202124;fontStyle=1;fontSize=13;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="40" y="130" width="810" height="366" as="geometry"/></mxCell>

    <mxCell id="acct" value="Account identity&#10;email, name, nickname, avatar URL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8;fontColor=#0b1b3a;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="55" y="170" width="250" height="90" as="geometry"/></mxCell>
    <mxCell id="sfident" value="Salesforce identity&#10;SF username, email, instanceUrl" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8;fontColor=#0b1b3a;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="320" y="170" width="250" height="90" as="geometry"/></mxCell>
    <mxCell id="activity" value="Login &amp; audit activity&#10;IP address, user-agent, email&#10;(retention 365 / 180 days)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8;fontColor=#0b1b3a;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="585" y="170" width="250" height="90" as="geometry"/></mxCell>

    <mxCell id="sessions" value="Sessions&#10;user, IP, user-agent&#10;(server-side; httpOnly cookie)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8;fontColor=#0b1b3a;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="55" y="275" width="250" height="90" as="geometry"/></mxCell>
    <mxCell id="pw" value="Passwords&#10;bcrypt — one-way hash&#10;(never stored reversibly)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8fd;strokeColor=#8430ce;fontColor=#2a0a4a;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="320" y="275" width="250" height="90" as="geometry"/></mxCell>
    <mxCell id="mfa" value="MFA / TOTP secrets&#10;additional field-level AES-256-GCM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f4ea;strokeColor=#137333;fontColor=#062916;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="585" y="275" width="250" height="90" as="geometry"/></mxCell>

    <mxCell id="sso" value="SSO secrets&#10;SAML key / OIDC secret&#10;additional field-level AES-256-GCM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f4ea;strokeColor=#137333;fontColor=#062916;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="55" y="380" width="250" height="90" as="geometry"/></mxCell>
    <mxCell id="sftok" value="Salesforce OAuth tokens&#10;(web app only)&#10;additional field-level AES-256-GCM, per-user key" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f4ea;strokeColor=#137333;fontColor=#062916;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="320" y="380" width="250" height="90" as="geometry"/></mxCell>
    <mxCell id="billing" value="Billing&#10;Stripe customer / subscription IDs only&#10;(no card data — Stripe holds all payments)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef7e0;strokeColor=#f9ab00;fontColor=#3a2c05;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="585" y="380" width="250" height="90" as="geometry"/></mxCell>

    <mxCell id="containerB" value="Salesforce RECORD data — the customer's data (may contain PII)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8f9fa;strokeColor=#9aa0a6;fontColor=#202124;fontStyle=1;fontSize=13;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="870" y="130" width="320" height="366" as="geometry"/></mxCell>
    <mxCell id="brec1" value="Web app&#10;proxied through server memory&#10;NOT persisted by Jetstream" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f3f4;strokeColor=#5f6368;fontColor=#202124;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="885" y="185" width="290" height="130" as="geometry"/></mxCell>
    <mxCell id="brec2" value="Extension · Desktop · Canvas&#10;never touches Jetstream servers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f3f4;strokeColor=#5f6368;fontColor=#202124;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="885" y="330" width="290" height="130" as="geometry"/></mxCell>

    <mxCell id="legend" value="Additional application-level protection —   Blue: personal data (encrypted at rest, used by the app)      Green: additionally field-level encrypted      Purple: one-way hashed      Amber: delegated / not stored" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9aa0a6;fontColor=#202124;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="510" width="1150" height="40" as="geometry"/></mxCell>
  </root>
</mxGraphModel>
