-- Mirrors apps/api/src/app/lib/permission-export/soql-templates.ts (buildFieldPermissionsByParentSoql).
-- Server may append: AND SobjectType IN (...) when the job payload includes objectApiNames.
SELECT Id, ParentId, SobjectType, Field,
  PermissionsRead, PermissionsEdit
FROM FieldPermissions
WHERE ParentId IN ({{PARENT_IDS}})
