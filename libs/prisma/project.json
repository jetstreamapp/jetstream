{
  "name": "prisma",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/prisma/src",
  "projectType": "library",
  "tags": ["scope:server"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{workspaceRoot}/prisma/schema.prisma", "{workspaceRoot}/prisma.config.ts", "{workspaceRoot}/prisma/sql/**/*"],
      "outputs": ["{projectRoot}/src/lib/generated/prisma"],
      "options": {
        "command": "prisma generate"
      }
    }
  }
}
