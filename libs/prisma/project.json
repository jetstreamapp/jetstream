{
  "name": "prisma",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/prisma/src",
  "projectType": "library",
  "tags": ["scope:server"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{workspaceRoot}/prisma/schema.prisma",
        "{workspaceRoot}/prisma.config.ts",
        "{workspaceRoot}/prisma/sql/**/*",
        { "externalDependencies": ["prisma", "@prisma/client"] }
      ],
      "outputs": ["{projectRoot}/src/lib/generated/prisma"],
      "options": {
        "commands": ["node -e \"fs.rmSync('libs/prisma/src/lib/generated/prisma', { recursive: true, force: true })\"", "prisma generate"],
        "parallel": false
      }
    }
  }
}
