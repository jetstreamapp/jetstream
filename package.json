{
  "name": "jetstream",
  "description": "The Jetstream platform makes managing your Salesforce instances a breeze. Use Jetstream to work with your data and metadata to get your work done faster.",
  "repository": {
    "type": "git",
    "url": "https://github.com/jetstreamapp/jetstream"
  },
  "author": "Jetstream Solutions, LLC",
  "version": "10.1.1",
  "license": "SEE LICENSE IN LICENSE.md",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "11.8.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "scripts": {
    "preinstall": "node scripts/check-package-manager.mjs",
    "init:project": "zx ./scripts/init-project.mjs",
    "update:pnpm": "node scripts/update-pnpm.mjs",
    "nx": "nx",
    "start": "nx serve",
    "start:api": "nx serve api",
    "start:geo-ip-api": "nx serve geo-ip-api",
    "start:geo-ip-api:prod": "node dist/apps/geo-ip-api/main.js",
    "start:worker": "nx serve jetstream-worker",
    "start:landing": "nx dev landing",
    "start:docs": "pnpm --dir apps/docs start",
    "start:prod": "cross-env NODE_ENV=production node --enable-source-maps dist/apps/api/main.js",
    "start:staging": "cross-env NODE_ENV=production node --enable-source-maps dist/apps/api/main.js",
    "start:e2e": "node dist/apps/api/main.js",
    "start:cron:save-analytics-summary": "node dist/apps/cron-tasks/save-analytics-summary.js",
    "start:cron:geo-ip-api-updater": "node dist/apps/cron-tasks/geo-ip-api-updater.js",
    "start:cron:salesforce-org-expiration": "node dist/apps/cron-tasks/salesforce-org-expiration.js",
    "start:cron:salesforce-org-expiration:test-mode": "TEST_MODE=true node dist/apps/cron-tasks/salesforce-org-expiration.js",
    "start:cron:cloudflare-spike-detector": "node dist/apps/cron-tasks/cloudflare-spike-detector.js",
    "start:cron:cloudflare-daily-digest": "node dist/apps/cron-tasks/cloudflare-daily-digest.js",
    "start:cron:cloudflare-analytics-archiver": "node dist/apps/cron-tasks/cloudflare-analytics-archiver.js",
    "start:web-ext:watch": "nx watch --projects=jetstream-web-extension -- nx run jetstream-web-extension:build --configuration=development",
    "start:web-ext:firefox": "web-ext run --source-dir=dist/apps/jetstream-web-extension --artifacts-dir=dist/web-extension-build --target=firefox-desktop --browser-console --devtools",
    "start:web-ext:chrome": "web-ext run --source-dir=dist/apps/jetstream-web-extension --artifacts-dir=dist/web-extension-build --target=chromium --browser-console --devtools",
    "start:desktop:client": "pnpm scripts:copy-monaco-assets:desktop && nx serve jetstream-desktop-client",
    "start:desktop": "pnpm nx run-many --target=build --parallel=2 --projects=jetstream-desktop --configuration=production && pnpm electron --inspect=9229 \"dist/apps/jetstream-desktop/main.js\"",
    "start:desktop:prod": "cross-env ENV=production pnpm electron dist/desktop-build/main.js",
    "build": "cross-env NODE_ENV=production npm-run-all db:generate generate:version build:core build:landing",
    "build:core": "cross-env NODE_OPTIONS=--max_old_space_size=8192 nx run-many --output-style=dynamic --target=build --parallel=3 --projects=jetstream,api --configuration=production",
    "build:ci": "pnpm nx run-many --output-style=static --target=build --parallel=3 --projects=jetstream,api,landing,jetstream-canvas,jetstream-web-extension,jetstream-desktop,jetstream-desktop-client --configuration=production",
    "build:affected": "nx affected --target=build --exclude jetstream-e2e,jetstream-desktop-client-e2e,jetstream-web-extension-e2e --parallel=3 --configuration=production",
    "build:docker": "cross-env NODE_ENV=production npm-run-all db:generate generate:version build:client:docker build:api:docker build:landing",
    "build:test": "npm-run-all db:generate generate:version build:client:test build:api:test build:landing",
    "build:client": "nx build jetstream --prod",
    "build:client:docker": "nx build jetstream --configuration=docker",
    "build:client:stats": "nx build jetstream --prod --statsJson",
    "build:client:test": "nx build jetstream --configuration=test --verbose",
    "build:ui": "nx build ui --configuration=docker",
    "build:ui:test": "nx build ui --configuration=test",
    "build:api": "nx build api --prod",
    "build:api:docker": "nx build api --configuration=docker",
    "build:geo-ip-api": "nx build geo-ip-api --prod",
    "build:cron": "pnpm db:generate && nx build cron-tasks --prod && pnpm generate:version",
    "build:api:test": "nx build api --configuration=test",
    "build:landing": "cross-env NODE_ENV=production nx run landing:build --skip-nx-cache && pnpm build:landing:sitemap",
    "build:landing:sitemap": "next-sitemap",
    "build:docs": "pnpm --dir apps/docs build",
    "build:canvas": "nx run jetstream-canvas:build --configuration=production",
    "build:canvas:dev": "nx run jetstream-canvas:build --configuration=development",
    "build:desktop": "node scripts/build-electron.mjs",
    "build:desktop:all": "pnpm scripts:copy-monaco-assets:desktop && cross-env NODE_OPTIONS=--max_old_space_size=8192 nx run-many --output-style=dynamic --target=build --parallel=3 --projects=jetstream-desktop,jetstream-desktop-client --configuration=production",
    "build:desktop:main": "nx build jetstream-desktop --configuration=production",
    "build:desktop:client": "pnpm scripts:copy-monaco-assets:desktop && nx build jetstream-desktop-client --configuration=production",
    "build:web-extension": "pnpm scripts:copy-monaco-assets:web-extension && nx run jetstream-web-extension:build",
    "build:web-extension:dev": "pnpm scripts:copy-monaco-assets:web-extension && nx run jetstream-web-extension:build --configuration=development",
    "build:web-extension:staging": "pnpm scripts:copy-monaco-assets:web-extension && nx run jetstream-web-extension:build --configuration=staging",
    "build:web-extension:zip": "node scripts/web-extension-zip.mjs",
    "build:web-extension:status": "node scripts/web-extension-publish.mjs --check-status",
    "build:web-extension:upload": "node scripts/web-extension-publish.mjs --upload -f dist/web-extension-build/web-extension.zip",
    "build:web-extension:publish": "node scripts/web-extension-publish.mjs --publish -f dist/web-extension-build/web-extension.zip",
    "publish:desktop:macos": "pnpm build:desktop && cd dist/desktop-build && pnpm publish:mac",
    "publish:desktop:windows": "pnpm build:desktop && cd dist\\desktop-build && pnpm publish:win",
    "email:dev": "email dev --dir ./libs/email/src/lib/email-templates --port 3003",
    "email:build": "email build --dir ./libs/email/src/lib/email-templates --packageManager pnpm",
    "scripts:replace-deps": "node ./scripts/replace-package-deps.mjs",
    "scripts:generate-env": "node ./scripts/generate.env.mjs",
    "scripts:copy-monaco-assets:desktop": "node scripts/copy-monaco-assets.mjs --target desktop",
    "scripts:copy-monaco-assets:web-extension": "node scripts/copy-monaco-assets.mjs --target web-extension",
    "release": "node scripts/release.mjs",
    "release:preview": "node scripts/release-preview.mjs",
    "hotfix": "node scripts/create-hotfix.mjs",
    "docs:index": "docker run -it -e APPLICATION_ID=21D7I5RB7N -e API_KEY=$ALGOLIA_API_KEY -e \"CONFIG=$(cat ./apps/docs/algolia-config.json | jq -r tostring)\" algolia/docsearch-scraper",
    "mock-idp:keys": "node mock-idp/gen-keys.mjs",
    "mock-idp:up": "pnpm mock-idp:keys && docker compose -f mock-idp/docker-compose.yml up -d",
    "mock-idp:down": "docker compose -f mock-idp/docker-compose.yml down",
    "mock-idp:logs": "docker compose -f mock-idp/docker-compose.yml logs -f",
    "generate:version": "zx ./scripts/generate-version.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "pnpm dlx prisma migrate deploy",
    "db:seed": "pnpm dlx prisma db seed",
    "icons:build": "npm-run-all icons:build:* && pnpm prettier --log-level error --write libs/icon-factory/src/lib/icons/**/*.tsx",
    "icons:build:action": "pnpm dlx @svgr/cli@5.5.0 --config-file .svgo-config.json -d ./libs/icon-factory/src/lib/icons/action ./node_modules/@salesforce-ux/design-system/assets/icons/action",
    "icons:build:custom": "pnpm dlx @svgr/cli@5.5.0 --config-file .svgo-config.json -d ./libs/icon-factory/src/lib/icons/custom ./node_modules/@salesforce-ux/design-system/assets/icons/custom",
    "icons:build:doctype": "pnpm dlx @svgr/cli@5.5.0 --config-file .svgo-config.json -d ./libs/icon-factory/src/lib/icons/doctype ./node_modules/@salesforce-ux/design-system/assets/icons/doctype",
    "icons:build:standard": "pnpm dlx @svgr/cli@5.5.0 --config-file .svgo-config.json -d ./libs/icon-factory/src/lib/icons/standard ./node_modules/@salesforce-ux/design-system/assets/icons/standard",
    "icons:build:utility": "pnpm dlx @svgr/cli@5.5.0 --config-file .svgo-config.json -d ./libs/icon-factory/src/lib/icons/utility ./node_modules/@salesforce-ux/design-system/assets/icons/utility",
    "test": "cross-env TZ=UTC nx test",
    "test:affected": "cross-env TZ=UTC nx affected -t test --output-style=stream",
    "test:all": "cross-env TZ=UTC nx run-many -t test --output-style=stream --skip-nx-cache",
    "lint:affected": "cross-env TZ=UTC nx affected -t lint --output-style=stream  --quiet",
    "lint:all": "cross-env TZ=UTC nx run-many -t lint --output-style=stream --skip-nx-cache --quiet",
    "e2e": "nx e2e",
    "playwright:open": "pnpm playwright open http://localhost:3333",
    "playwright:test:with-server": "pnpm start-server-and-test --expect 200 \"pnpm start:e2e\" http://localhost:3333 \"pnpm playwright:test\"",
    "playwright:test": "pnpm playwright test src --config apps/jetstream-e2e/playwright.config.ts",
    "playwright:test:query-results": "pnpm playwright test query-results.spec.ts --config apps/jetstream-e2e/playwright.config.ts --headed",
    "playwright:web-extension:test": "pnpm playwright test src --config apps/jetstream-web-extension-e2e/playwright.config.ts --headed",
    "playwright:web-extension:open": "pnpm playwright open http://localhost:3333 --config apps/jetstream-web-extension-e2e/playwright.config.ts",
    "format": "nx format:write",
    "format:write": "nx format:write",
    "format:check": "nx format:check",
    "organize-imports": "node scripts/organize-imports.mjs",
    "organize-imports:check": "node scripts/organize-imports.mjs --check",
    "update": "nx migrate latest",
    "dep-graph": "nx dep-graph",
    "prepare": "husky"
  },
