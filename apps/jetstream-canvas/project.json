{
  "name": "jetstream-canvas",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/jetstream-canvas/src",
  "projectType": "application",
  "tags": ["scope:browser"],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/jetstream-canvas"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "jetstream-canvas:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "jetstream-canvas:build:development",
          "hmr": true
        },
        "production": {
          "buildTarget": "jetstream-canvas:build:production",
          "hmr": false
        }
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/apps/jetstream-canvas"
      }
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "jetstream-canvas:build",
        "spa": true
      }
    }
  }
}
