{
  "name": "cron-tasks",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/cron-tasks/src",
  "projectType": "application",
  "tags": ["scope:server", "scope:cron-tasks"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/cron-tasks",
        "format": ["cjs"],
        "bundle": true,
        "main": "apps/cron-tasks/src/main.ts",
        "additionalEntryPoints": [
          "apps/cron-tasks/src/clean-up-user-sync-history.ts",
          "apps/cron-tasks/src/save-analytics-summary.ts",
          "apps/cron-tasks/src/geo-ip-api-updater.ts",
          "apps/cron-tasks/src/geo-ip-db-updater.ts",
          "apps/cron-tasks/src/salesforce-org-expiration.ts",
          "apps/cron-tasks/src/stats-summary.ts",
          "apps/cron-tasks/src/cloudflare-spike-detector.ts",
          "apps/cron-tasks/src/cloudflare-daily-digest.ts"
        ],
        "tsConfig": "apps/cron-tasks/tsconfig.app.json",
        "assets": [],
        "generatePackageJson": true,
        "sourcemap": true,
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "cron-tasks:build",
        "inspect": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/apps/cron-tasks"
      }
    }
  }
}
