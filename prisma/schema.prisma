generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  userId      String    @unique
  email       String
  name        String?
  nickname    String?
  picture     String?
  appMetadata String? // Changed from Json to String
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SalesforceApi {
  id               String   @id @default(uuid()) // Changed from dbgenerated("uuid_generate_v4()")
  groupName        String?
  groupDescription String?
  name             String?
  description      String?
  method           String?
  url              String?
  header           String?
  body             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("salesforce_api")
}

model SalesforceOrg {
  id                     String    @id @default(uuid())
  jetstreamUserId        String
  uniqueId               String
  filterText             String
  accessToken            String
  instanceUrl            String
  loginUrl               String
  userId                 String
  email                  String
  organizationId         String
  username               String
  displayName            String
  thumbnail              String?
  apiVersion             String?
  orgName                String?
  orgCountry             String?
  orgInstanceName        String?
  orgIsSandbox           Boolean?
  orgLanguageLocaleKey   String?
  orgNamespacePrefix     String?
  orgTrialExpirationDate DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  connectionError        String?
  jetstreamUrl           String?
  label                  String?
  orgOrganizationType    String?
  color                  String?

  @@unique([jetstreamUserId, jetstreamUrl, uniqueId], name: "uniqueOrg")
  @@map("salesforce_org")
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model AnalyticsSummary {
  id        String   @id @default(uuid()) // Changed from dbgenerated("uuid_generate_v4()")
  type      String   @unique
  week      Int
  month     Int
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
